{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/play/:id", "destination": "/play.html?id=:id" },
    { "source": "/games", "destination": "/games.html" },
    { "source": "/home", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/games/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" }
      ]
    }
  ]
}
